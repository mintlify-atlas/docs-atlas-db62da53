  "keyFeatures": [
    "Draggable, transparent ScreenGui panel with rounded corners",
    "Float toggle — zeroes workspace gravity and enables PlatformStand",
    "Fly mode with WASD/QE controls, BodyVelocity/BodyGyro physics, Shift to slow down",
    "Sprint (WalkSpeed 100) and Slow Walk (WalkSpeed 6) toggles",
    "High Jump (JumpPower 200) toggle",
    "Sit toggle via Humanoid.Sit",
    "Super Spin — instant angular velocity trick",
    "Player Teleport list that auto-updates as players join/leave",
    "Infinite Yield loader shortcut",
    "Jorkin easter-egg tool with R6/R15 animation support"
  ],
  "publicApiSurface": [
    "loadstring(game:HttpGet('https://raw.githubusercontent.com/Kaladoo2/KCSH/refs/heads/main/source.lua'))()",
